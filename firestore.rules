rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Notes: owner can read/write; folder members can read
    match /notes/{noteId} {
      allow read: if request.auth != null &&
        (resource.data.ownerId == request.auth.uid ||
         exists(/databases/$(database)/documents/folders/$(resource.data.folderId)) &&
         get(/databases/$(database)/documents/folders/$(resource.data.folderId)).data.allowedUsers.hasAny([request.auth.uid]) ||
         get(/databases/$(database)/documents/folders/$(resource.data.folderId)).data.ownerId == request.auth.uid);
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && resource.data.ownerId == request.auth.uid;
    }
    
    // Folders: owner can read/write; members (in allowedUsers) can read
    match /folders/{folderId} {
      allow read: if request.auth != null &&
        (resource.data.ownerId == request.auth.uid ||
         resource.data.allowedUsers.hasAny([request.auth.uid]));
      allow create: if request.auth != null;
      allow update: if request.auth != null &&
        (resource.data.ownerId == request.auth.uid ||
         resource.data.allowedUsers.hasAny([request.auth.uid]));
      allow delete: if request.auth != null && resource.data.ownerId == request.auth.uid;
    }
    
    // Invites: sender can create/read; target user can read and update status
    match /invites/{inviteId} {
      allow read: if request.auth != null &&
        (resource.data.senderId == request.auth.uid ||
         resource.data.targetUserId == request.auth.uid ||
         resource.data.status == 'active');
      allow create: if request.auth != null;
      allow update: if request.auth != null &&
        (resource.data.senderId == request.auth.uid ||
         resource.data.targetUserId == request.auth.uid ||
         resource.data.requesterId == request.auth.uid);
      allow delete: if request.auth != null && resource.data.senderId == request.auth.uid;
    }
  }
}