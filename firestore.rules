rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to check if user is a member of a folder
    function isFolderMember(folderId) {
      let folder = get(/databases/$(database)/documents/folders/$(folderId));
      return request.auth != null && (
        folder.data.ownerId == request.auth.uid ||
        request.auth.uid in folder.data.get('allowedUsers', [])
      );
    }

    // Notes: owner can read/write; folder members can read
    match /notes/{noteId} {
      allow read: if request.auth != null && (
        resource.data.ownerId == request.auth.uid ||
        isFolderMember(resource.data.folderId)
      );
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && resource.data.ownerId == request.auth.uid;
    }
    
    // Folders: owner can read/write; members (in allowedUsers) can read
    match /folders/{folderId} {
      allow read: if request.auth != null && (
        resource.data.ownerId == request.auth.uid ||
        request.auth.uid in resource.data.get('allowedUsers', [])
      );
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        resource.data.ownerId == request.auth.uid ||
        request.auth.uid in resource.data.get('allowedUsers', [])
      );
      allow delete: if request.auth != null && resource.data.ownerId == request.auth.uid;
    }
    
    // Invites: sender can create/read; target user can read and update status
    match /invites/{inviteId} {
      allow read: if request.auth != null &&
        (resource.data.get('senderId', '') == request.auth.uid ||
         resource.data.get('targetUserId', '') == request.auth.uid ||
         resource.data.get('requesterId', '') == request.auth.uid ||
         resource.data.status == 'active');
      allow create: if request.auth != null;
      allow update: if request.auth != null &&
        (resource.data.status == 'active' || // Anyone can start a join request
         resource.data.senderId == request.auth.uid ||
         resource.data.targetUserId == request.auth.uid ||
         resource.data.requesterId == request.auth.uid);
      allow delete: if request.auth != null && resource.data.senderId == request.auth.uid;
    }
  }
}